# ================================
# PMU Platform - Environment Variables
# ================================
# Copy this file to .env and fill in your values

# --- Backend ---
NODE_ENV=development
PORT=4000
# MySQL connection string used by Prisma and the AI engine (aiomysql)
DATABASE_URL=mysql://root:@localhost:3306/pmu_db
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- AI Engine ---
# Provider: mock | anthropic | groq
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_ENGINE_URL=http://localhost:8000

# --- SMS Provider ---
# Available: mock | orange | twilio
SMS_PROVIDER=mock
SMS_API_KEY=your_sms_api_key
SMS_SENDER=PMU-PRONO
# Required only when SMS_PROVIDER=twilio
SMS_TWILIO_ACCOUNT_SID=

# --- Sports APIs (API-Football / API-Basketball via api-sports.io) ---
# Leave blank to use mock data (no API calls)
FOOTBALL_API_KEY=
FOOTBALL_API_BASE=https://v3.football.api-sports.io
BASKETBALL_API_KEY=
BASKETBALL_API_BASE=https://v1.basketball.api-sports.io

# --- Frontend ---
VITE_API_URL=http://localhost:4000/api
VITE_AI_ENGINE_URL=http://localhost:8000
