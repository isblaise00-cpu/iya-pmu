generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Plan {
  id           Int          @id @default(autoincrement())
  name         String
  price        Float
  durationDays Int
  description  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  subscribers  Subscriber[]
  payments     Payment[]

  @@map("plans")
}

model Subscriber {
  id        Int              @id @default(autoincrement())
  phone     String           @unique
  name      String
  status    SubscriberStatus @default(ACTIVE)
  planId    Int
  plan      Plan             @relation(fields: [planId], references: [id])
  startDate DateTime         @default(now())
  endDate   DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  smsLogs   SmsLog[]
  payments  Payment[]

  @@map("subscribers")
}

enum SubscriberStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

model Race {
  id         Int        @id @default(autoincrement())
  date       DateTime   @unique @db.Date
  raceType   String?
  raceName   String?
  hippodrome String?
  distance   Int?
  numHorses  Int?
  startTime  String?
  pdfUrl     String?    @db.VarChar(500)
  createdAt  DateTime   @default(now())
  pronostic  Pronostic?

  @@map("races")
}

model Pronostic {
  id              Int      @id @default(autoincrement())
  date            DateTime @default(now())
  horses          Json?
  proposals       Json?
  commentary      String?  @db.Text
  isSent          Boolean  @default(false)
  modifiedByAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())
  raceId          Int?     @unique
  race            Race?    @relation(fields: [raceId], references: [id])
  result          Result?

  @@map("pronostics")
}

model Result {
  id           Int        @id @default(autoincrement())
  date         DateTime   @default(now())
  arrivalOrder Json?
  source       String?
  pronosticId  Int?       @unique
  pronostic    Pronostic? @relation(fields: [pronosticId], references: [id])
  createdAt    DateTime   @default(now())

  @@map("results")
}

model SmsCampaign {
  id        Int            @id @default(autoincrement())
  name      String
  message   String
  status    CampaignStatus @default(DRAFT)
  target    String         @default("all")
  sentAt    DateTime?
  createdAt DateTime       @default(now())
  logs      SmsLog[]

  @@map("sms_campaigns")
}

enum CampaignStatus {
  DRAFT
  SENT
  FAILED
}

model SmsLog {
  id           Int          @id @default(autoincrement())
  subscriberId Int?
  subscriber   Subscriber?  @relation(fields: [subscriberId], references: [id])
  message      String
  status       SmsLogStatus @default(PENDING)
  campaignId   Int?
  campaign     SmsCampaign? @relation(fields: [campaignId], references: [id])
  sentAt       DateTime     @default(now())
  errorMessage String?

  @@map("sms_logs")
}

enum SmsLogStatus {
  PENDING
  SENT
  FAILED
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

model Payment {
  id           Int        @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  amount       Float
  planId       Int
  plan         Plan       @relation(fields: [planId], references: [id])
  note         String?
  paymentDate  DateTime   @default(now())
  createdAt    DateTime   @default(now())

  @@map("payments")
}

// ─── Multi-sports (football + basketball) ───────────────────────────────────

model SportEvent {
  id         Int      @id @default(autoincrement())
  sport      String // "FOOTBALL" | "BASKETBALL"
  date       DateTime @db.Date
  league     String
  homeTeam   String
  awayTeam   String
  kickoff    String // "HH:MM"
  externalId String // identifiant côté API source
  createdAt  DateTime @default(now())

  pronostic SportPronostic?
  result    SportResult?

  @@unique([sport, externalId])
  @@index([sport, date])
  @@map("sport_events")
}

model SportPronostic {
  id              Int      @id @default(autoincrement())
  eventId         Int      @unique
  sport           String
  date            DateTime @db.Date
  modelProbs      Json // sortie brute du modèle statistique
  predictions     Json // marchés conseillés + confiance
  valueBets       Json // paris à edge positif
  commentary      String   @db.Text
  confidence      Int // 0-100
  isSent          Boolean  @default(false)
  modifiedByAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())

  event SportEvent @relation(fields: [eventId], references: [id])

  @@map("sport_pronostics")
}

model SportResult {
  id        Int      @id @default(autoincrement())
  eventId   Int      @unique
  sport     String
  homeScore Int?
  awayScore Int?
  outcome   String? // "HOME" | "DRAW" | "AWAY"
  source    String?
  createdAt DateTime @default(now())

  event SportEvent @relation(fields: [eventId], references: [id])

  @@map("sport_results")
}
